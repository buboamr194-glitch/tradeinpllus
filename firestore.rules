rules_version = '2';

// TradeInPlus Firestore Security Rules
// Deploy: Firebase Console > Firestore > Rules > paste this > Publish

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: check if user is authenticated ───
    function isAuth() {
      return request.auth != null;
    }

    // ─── Helper: check if user is admin ───
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Helper: check if user has a role in admins collection ───
    function hasRole(role) {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == role;
    }

    // ─── Helper: check if user is admin or manager ───
    function isAdminOrManager() {
      return isAdmin() || hasRole('manager');
    }

    // ─── Orders: anyone can CREATE (website checkout) with validation ───
    match /orders/{orderId} {
      // Validate order shape on create to prevent abuse
      allow create: if request.resource.data.keys().hasAll(['orderNumber', 'productName', 'customerName', 'customerPhone'])
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 1
        && request.resource.data.customerName.size() < 100
        && request.resource.data.customerPhone is string
        && request.resource.data.customerPhone.size() >= 10
        && request.resource.data.customerPhone.size() < 20
        && request.resource.data.orderNumber is string
        && request.resource.data.orderNumber.size() < 50;
      allow read: if isAuth();
      allow update: if isAuth();  // Staff can update status
      allow delete: if isAdmin();  // Only admin can delete
    }

    // ─── Products: anyone can READ (website), only auth users can write ───
    match /products/{productId} {
      allow read: if true;  // Public — website needs to show products
      allow create, update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ─── Stores: anyone can READ (website), only admin can write ───
    match /stores/{storeId} {
      allow read: if true;  // Public — website shows store locations
      allow write: if isAdmin();
    }

    // ─── Admin profiles: only the user themselves or an admin can read ───
    match /admins/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ─── Deny everything else by default ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
