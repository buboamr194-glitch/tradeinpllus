rules_version = '2';

// TradeInPlus Firebase Storage Security Rules
// Deploy: Firebase Console > Storage > Rules > paste this > Publish

service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user is admin or manager
    function isAdminOrManager() {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // Helper: validate image upload (max 5MB, image type only)
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Product images: public read, only admin/manager can write ───
    match /products/{filename} {
      allow read: if true; // Public — website shows product images
      allow write: if isAdminOrManager() && isValidImage();
      allow delete: if isAdmin();
    }

    // ─── Trade-in customer uploads (max 4 photos per submission) ───
    match /trade-ins/{submissionId}/{filename} {
      allow read: if isAuth(); // Only staff can view
      allow create: if isValidImage(); // Anyone can upload (for trade-in submissions)
      allow delete: if isAdmin();
    }

    // ─── Deny everything else by default ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
